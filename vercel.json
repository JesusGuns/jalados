{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/babyshower/:id",
      "destination": "/templates/BabyShower_:id.html"
    },
    {
      "source": "/xv/:id",
      "destination": "/templates/XV_:id.html"
    },
    {
      "source": "/wedding/:id",
      "destination": "/templates/Wedding_:id.html"
    },
    {
      "source": "/:tipo(wedding-[^/]+|babyshower-[^/]+|xv-[^/]+)/:token",
      "destination": "/clientes/:tipo/index.html?token=:token"
    },
    {
      "source": "/:tipo(wedding-[^/]+|babyshower-[^/]+|xv-[^/]+)",
      "destination": "/clientes/:tipo/index.html"
    }
  ]
}